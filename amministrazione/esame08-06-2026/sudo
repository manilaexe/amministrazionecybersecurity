#Definisci Host_Alias RUNNERS = runner01, runner02
Host_Alias RUNNERS = runner01, runner02

#Definisci Cmnd_Alias USERMGM = /usr/sbin/useradd, /usr/sbin/userdel, /usr/sbin/usermod, Cmnd_Alias NETINFO = /usr/bin/ip, /usr/bin/ss e Cmnd_Alias PKGINFO = /usr/bin/dpkg, /usr/bin/apt
#letteralmente spacchetti la consegna
Cmnd_Alias USERMGM = /usr/sbin/useradd, /usr/sbin/userdel, /usr/sbin/usermod
Cmnd_Alias NETINFO = /usr/bin/ip, /usr/bin/ss
Cmnd_Alias PKGINFO = /usr/bin/dpkg, /usr/bin/apt

#STRUTTRUA GENERALE: CHI   SU QUALI HOST   =   (COME CHI)   COSA PUÒ FARE

#nora può eseguire qualsiasi comando come qualsiasi utente su qualsiasi host
nora ALL = (ALL) ALL

#omar può eseguire qualsiasi comando come qualsiasi utente su qualsiasi host, eccetto USERMGM
omar ALL = (ALL) ALL, !USERMGM

#%dev può eseguire NETINFO come root su RUNNERS
%dev RUNNERS = NETINFO

#%sec può eseguire PKGINFO come root su registry01, senza password
%sec registry01= NOPASSWD: PKGINFO

#priya può eseguire /usr/bin/cat /etc/shadow come root su qualsiasi host, senza password
priya ALL = NOPASSWD: /usr/bin/cat /etc/shadow 

#quinn può eseguire /usr/bin/id come ravi su RUNNERS
quinn RUNNERS = (ravi) /usr/bin/id

#%ops, %dev può eseguire /usr/bin/tcpdump come root su qualsiasi host, senza password
%ops , %dev ALL = NOPASSWD: /usr/bin/tcpdump
